# Copy to backend/.env (never commit .env). Loaded by backend/app/config.py from
# backend/.env regardless of process cwd.

# --- Core (required for a running API) ---
APP_NAME=Tooth API
ENVIRONMENT=development
DEBUG=false
API_PREFIX=/api/v1
DATABASE_URL=postgresql+psycopg://tooth:tooth@127.0.0.1:55432/tooth
DATA_DIR=/home/joakim/tooth/data

JWT_SECRET_KEY=change-me-before-production-phase
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=480

BOOTSTRAP_EMAIL=admin@example.com
BOOTSTRAP_PASSWORD=tooth-dev-password

# --- Phase 4 (OpenAI-compatible provider; required for /api/v1/ai/*) ---
# Exact names match the OpenAI Python SDK environment contract.
OPENAI_API_KEY=
# Optional: override API base URL (compatible proxies, Azure OpenAI mapping, etc.).
OPENAI_BASE_URL=
# Default / primary model id (used as expensive path when OPENAI_EXPENSIVE_MODEL is unset).
OPENAI_DEFAULT_MODEL=
# Cheap routing passes (classification, lightweight answer) vs escalation (deep model).
OPENAI_CHEAP_MODEL=gpt-5.4-mini
OPENAI_EXPENSIVE_MODEL=gpt-5.4
AI_MAX_CONTEXT_CHARS=12000
AI_MAX_USER_MESSAGE_CHARS=4000
AI_MAX_CHEAP_ROUNDS=3

# --- Phase 5 (search + embeddings + paste ingest) ---
# Embeddings for semantic/hybrid search (text-embedding-3-small is the default in config).
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_MAX_CHARS=8000
SEARCH_MAX_RESULTS=25
SEMANTIC_SCAN_MAX_RAW_TEXTS=500
PASTE_MAX_CHARS=50000

# --- Phase 6 (books) + AI assist retrieval snippets (when use_retrieval=true) ---
AI_RETRIEVAL_EXCERPT_CHARS=800
AI_RETRIEVAL_MAX_HITS=5
